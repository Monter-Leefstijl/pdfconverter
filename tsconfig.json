{
  "compilerOptions": {
    "module": "Node16",
    "target": "ES2023",
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "sourceMap": false,
    "removeComments": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "strict": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "alwaysStrict": true,
    "lib": ["ES2022", "DOM"],
    "skipLibCheck": true
  },
  "exclude": ["node_modules"],
  "include": ["index.ts", "tests/**/*.ts"]
}
